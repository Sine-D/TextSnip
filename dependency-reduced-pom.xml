<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <groupId>com.snap</groupId>
  <artifactId>snap-ocr</artifactId>
  <version>1.0-SNAPSHOT</version>
  <build>
    <plugins>
      <plugin>
        <artifactId>maven-shade-plugin</artifactId>
        <version>3.5.1</version>
        <executions>
          <execution>
            <phase>package</phase>
            <goals>
              <goal>shade</goal>
            </goals>
            <configuration>
              <filters>
                <filter>
                  <artifact>*:*</artifact>
                  <excludes>
                    <exclude>META-INF/*.SF</exclude>
                    <exclude>META-INF/*.DSA</exclude>
                    <exclude>META-INF/*.RSA</exclude>
                  </excludes>
                </filter>
              </filters>
              <transformers>
                <transformer>
                  <mainClass>com.snap.App</mainClass>
                </transformer>
              </transformers>
              <shadedArtifactAttached>false</shadedArtifactAttached>
              <finalName>TextSnip</finalName>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>com.akathist.maven.plugins.launch4j</groupId>
        <artifactId>launch4j-maven-plugin</artifactId>
        <version>2.4.1</version>
        <executions>
          <execution>
            <id>l4j-clui</id>
            <phase>package</phase>
            <goals>
              <goal>launch4j</goal>
            </goals>
            <configuration>
              <headerType>gui</headerType>
              <outfile>${project.basedir}/dist/TextSnip.exe</outfile>
              <jar>${project.build.directory}/TextSnip.jar</jar>
              <errTitle>TextSnip Error</errTitle>
              <classPath>
                <mainClass>com.snap.App</mainClass>
              </classPath>
              <jre>
                <path>jre</path>
                <bundledJre64Bit>true</bundledJre64Bit>
                <bundledJreAsFallback>false</bundledJreAsFallback>
              </jre>
              <versionInfo>
                <fileVersion>1.0.0.0</fileVersion>
                <txtFileVersion>1.0</txtFileVersion>
                <fileDescription>TextSnip OCR Application</fileDescription>
                <copyright>All Rights Reserved - Sineth Dinsara</copyright>
                <productVersion>1.0.0.0</productVersion>
                <txtProductVersion>1.0</txtProductVersion>
                <productName>TextSnip</productName>
                <internalName>TextSnip</internalName>
                <originalFilename>TextSnip.exe</originalFilename>
              </versionInfo>
            </configuration>
          </execution>
        </executions>
      </plugin>
      <plugin>
        <groupId>org.codehaus.mojo</groupId>
        <artifactId>exec-maven-plugin</artifactId>
        <version>3.1.0</version>
        <executions>
          <execution>
            <id>default-cli</id>
            <configuration>
              <mainClass>com.snap.App</mainClass>
            </configuration>
          </execution>
          <execution>
            <id>build-jre</id>
            <phase>package</phase>
            <goals>
              <goal>exec</goal>
            </goals>
            <configuration>
              <executable>${java.home}/bin/jlink</executable>
              <arguments>
                <argument>--add-modules</argument>
                <argument>java.base,java.desktop,java.logging,java.compiler,java.management,java.naming,java.sql,java.xml</argument>
                <argument>--no-header-files</argument>
                <argument>--no-man-pages</argument>
                <argument>--compress=2</argument>
                <argument>--output</argument>
                <argument>${project.basedir}/dist/jre</argument>
              </arguments>
            </configuration>
          </execution>
        </executions>
      </plugin>
    </plugins>
  </build>
  <properties>
    <maven.compiler.target>17</maven.compiler.target>
    <maven.compiler.source>17</maven.compiler.source>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>
</project>
